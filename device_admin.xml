<?xml version="1.0" encoding="utf-8"?>
<!--
  This file declares the Device Administrator capabilities.
  Place this at: android/app/src/main/res/xml/device_admin.xml
  
  When the user grants Device Administrator to JEE Alarm,
  they CANNOT uninstall the app without first going to:
  Settings → Security → Device Admin Apps → JEE Alarm → Deactivate
  THEN uninstalling.
  
  At 6am after a wrong alarm bypass attempt, this is psychologically
  very effective — nobody does this half-asleep.
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-policies>
    <!-- Prevents instant uninstall — must deactivate first -->
    <limit-password />
    <watch-login />
    <!-- Most importantly: keeps the app "protected" -->
  </uses-policies>
</device-admin>
